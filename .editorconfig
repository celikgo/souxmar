root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{cpp,cc,cxx,h,hpp,hxx,c}]
indent_size = 2
max_line_length = 100

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,json,jsonc}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.{yml,yaml,toml}]
indent_size = 2
