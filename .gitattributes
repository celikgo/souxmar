* text=auto eol=lf

# Always LF for source
*.c           text eol=lf
*.cc          text eol=lf
*.cpp         text eol=lf
*.cxx         text eol=lf
*.h           text eol=lf
*.hpp         text eol=lf
*.hxx         text eol=lf
*.in          text eol=lf
*.cmake       text eol=lf
CMakeLists.txt text eol=lf
*.py          text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.json        text eol=lf
*.toml        text eol=lf
*.yaml        text eol=lf
*.yml         text eol=lf
*.md          text eol=lf

# Windows scripts must remain CRLF
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# Treat as binary
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.pdf         binary
*.zip         binary
*.tar.gz      binary
*.dmg         binary
*.msi         binary
*.exe         binary
*.so          binary
*.dylib       binary
*.dll         binary
*.vtu         binary
*.vtp         binary
*.step        binary
*.stp         binary
*.iges        binary
*.igs         binary
*.stl         binary
*.blend       binary
