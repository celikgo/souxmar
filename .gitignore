# Build output
build/
build-*/
out/
cmake-build-*/

# Dependencies
node_modules/
target/
.pnpm-store/
vcpkg_installed/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Generated
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local
.env
.env.local
*.log
.souxmar/cache/
.souxmar/chat/

# Sprint 10 push 8 — dev signing private key, regenerated by
# scripts/release/regenerate-dev-key.sh. NEVER COMMIT.
scripts/release/dev-signing-key.local.txt

# Tauri
src-tauri/target/
# Tauri 2 autogenerates platform config + ACL schema files under
# src-tauri/gen/ on first build — derived from tauri.conf.json so
# they're not part of the source tree.
src/desktop/src-tauri/gen/

# Desktop (vite + tauri) build outputs and lockfiles. The repo doesn't
# track Cargo.lock or package-lock.json today — leave dependency
# resolution to the developer's local toolchain.
src/desktop/dist/
src/desktop/package-lock.json
src/desktop/src-tauri/Cargo.lock
# tsc -b incremental cache; regenerated on every typecheck.
src/desktop/tsconfig.tsbuildinfo

# Claude Code IDE local settings (per-user allowlist of tool calls).
.claude/settings.local.json

# Coverage
coverage/
*.gcda
*.gcno
*.profraw

# Sprint 11 push 1 — Playwright visual harness outputs.
# Baselines under tests/visual/specs/**/*-snapshots/ are committed;
# the rest of these are run artefacts.
tests/visual/test-results/
tests/visual/playwright-report/
tests/visual/.cache/

# Sprint 15 push 2 — per-project AI provider config (ADR-0020).
# project.ai.toml is gitignored by default because it's
# secrets-adjacent. Projects that share their AI config
# deliberately can `git add -f` it.
project.ai.toml
**/project.ai.toml
