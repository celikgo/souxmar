{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "dev",
      "displayName": "Local development (Debug)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SOUXMAR_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev-python",
      "displayName": "Local development with pysouxmar bindings (Debug)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SOUXMAR_BUILD_TESTS": "ON",
        "SOUXMAR_BUILD_PYTHON": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests;python"
      }
    },
    {
      "name": "ci-linux-gcc",
      "displayName": "CI: Linux + GCC 13 (RelWithDebInfo)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "gcc-13",
        "CMAKE_CXX_COMPILER": "g++-13",
        "SOUXMAR_BUILD_TESTS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "ci-linux-clang",
      "displayName": "CI: Linux + Clang 17 (RelWithDebInfo)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang-17",
        "CMAKE_CXX_COMPILER": "clang++-17",
        "SOUXMAR_BUILD_TESTS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "ci-macos",
      "displayName": "CI: macOS arm64 + AppleClang (RelWithDebInfo)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SOUXMAR_BUILD_TESTS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "ci-windows",
      "displayName": "CI: Windows x64 + MSVC (RelWithDebInfo)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "SOUXMAR_BUILD_TESTS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "asan",
      "displayName": "Local: AddressSanitizer + UBSan (Debug)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SOUXMAR_ENABLE_ASAN": "ON",
        "SOUXMAR_ENABLE_UBSAN": "ON",
        "SOUXMAR_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "tsan",
      "displayName": "Local: ThreadSanitizer (Debug)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SOUXMAR_ENABLE_TSAN": "ON",
        "SOUXMAR_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev",            "configurePreset": "dev",            "jobs": 0 },
    { "name": "dev-python",     "configurePreset": "dev-python",     "jobs": 0 },
    { "name": "ci-linux-gcc",   "configurePreset": "ci-linux-gcc",   "jobs": 0 },
    { "name": "ci-linux-clang", "configurePreset": "ci-linux-clang", "jobs": 0 },
    { "name": "ci-macos",       "configurePreset": "ci-macos",       "jobs": 0 },
    { "name": "ci-windows",     "configurePreset": "ci-windows",     "jobs": 0 },
    { "name": "asan",           "configurePreset": "asan",           "jobs": 0 },
    { "name": "tsan",           "configurePreset": "tsan",           "jobs": 0 }
  ],
  "testPresets": [
    {
      "name": "default-test",
      "hidden": true,
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    { "name": "dev",            "configurePreset": "dev",            "inherits": "default-test" },
    { "name": "dev-python",     "configurePreset": "dev-python",     "inherits": "default-test" },
    { "name": "ci-linux-gcc",   "configurePreset": "ci-linux-gcc",   "inherits": "default-test" },
    { "name": "ci-linux-clang", "configurePreset": "ci-linux-clang", "inherits": "default-test" },
    { "name": "ci-macos",       "configurePreset": "ci-macos",       "inherits": "default-test" },
    { "name": "ci-windows",     "configurePreset": "ci-windows",     "inherits": "default-test" },
    { "name": "asan",           "configurePreset": "asan",           "inherits": "default-test" },
    { "name": "tsan",           "configurePreset": "tsan",           "inherits": "default-test" }
  ]
}
