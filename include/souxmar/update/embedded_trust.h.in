// SPDX-License-Identifier: Apache-2.0
//
// Auto-updater — built-in trust store (Sprint 10 push 8).
//
// This header is generated by CMake. The release pipeline injects the
// project's official release ed25519 public key at configure time via
// -DSOUXMAR_RELEASE_PUBKEY_HEX=... + -DSOUXMAR_RELEASE_PUBKEY_ID=...
// The fallback values are a *dev-only test key* whose private half
// ships in the repo (scripts/release/dev-signing-key.txt) so
// developers can produce signed manifests in local builds without
// any HSM dance.
//
// **Never** ship a release build with the dev key. The release CI
// workflow asserts SOUXMAR_RELEASE_PUBKEY_ID != "souxmar-dev-key"
// before producing artefacts.

#pragma once

#include "souxmar/update/verifier.h"

namespace souxmar::update {

// Build-time-baked key id + 64-hex public key. Generated from
// embedded_trust.h.in; the .h is regenerated whenever the cmake
// cache value changes.
inline constexpr const char* kEmbeddedReleaseKeyId  = "@SOUXMAR_RELEASE_PUBKEY_ID@";
inline constexpr const char* kEmbeddedReleasePubkeyHex =
    "@SOUXMAR_RELEASE_PUBKEY_HEX@";

// Construct the default trust store the CLI uses when the user has
// not passed --trusted-key. Adds the embedded release key plus, if
// the build was configured with -DSOUXMAR_ALLOW_DEV_KEY=ON (default
// for non-release builds), the souxmar-dev key.
[[nodiscard]] TrustStore embedded_trust_store();

// True iff this build was configured with the development key
// (souxmar-dev-key). Release CI checks this and refuses to publish
// artefacts when true.
[[nodiscard]] bool build_uses_dev_key() noexcept;

}  // namespace souxmar::update
